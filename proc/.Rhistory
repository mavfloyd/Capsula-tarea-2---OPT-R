matriz_cor <- cor(variables_correlacion, use = "complete.obs")
# 3. Formateamos la tabla para el reporte formal (Exportada a la carpeta tables)
tabla_correlaciones <- matriz_cor %>%
kable(caption = "Tabla 4. Matriz de correlaciones de Pearson",
digits = 2,
format = "html",
col.names = c("Sueldo Líquido", "Edad", "Escala Meritocracia")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"), full_width = F)

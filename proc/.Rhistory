geom_histogram(fill = "steelblue", color = "white", bins = 50) +
geom_vline(aes(xintercept = median(sueldo)), color = "red", linetype = "dashed", size = 1) +
# Ajustamos el eje X con etiquetas simplificadas
scale_x_continuous(
# scale = 1e-6 divide el valor original por 1.000.000
labels = label_number(scale = 1e-6, prefix = "$", suffix = "M", big.mark = "."),
breaks = seq(0, 20000000, by = 1000000)
) +
labs(title = "Distribución del Sueldo Líquido Mensual",
subtitle = "La línea roja indica la mediana ($415.000). Etiquetas en millones de pesos (M).",
x = "Sueldo",
y = "Frecuencia",
caption = "Fuente: Elaboración propia en base a ELSOC 2016-2023") +
theme_minimal()
ggplot(elsoc_proc, aes(x = sueldo)) +
geom_histogram(fill = "steelblue", color = "white", bins = 50) +
geom_vline(aes(xintercept = median(sueldo)), color = "red", linetype = "dashed", size = 1) +
# Usamos una función personalizada dentro de labels
scale_x_continuous(
breaks = seq(0, 20000000, by = 1000000), # Cortes cada 1 millón
labels = function(x) {
# Si el número es 0, lo dejamos como $0. Si no, lo dividimos por un millón y le pegamos la M
ifelse(x == 0, "$0", paste0("$", x/1000000, "M"))
}
) +
labs(title = "Distribución del Sueldo Líquido Mensual",
subtitle = "La línea roja indica la mediana. Eje X en millones de pesos (M)",
x = "Sueldo",
y = "Frecuencia",
caption = "Fuente: ELSOC 2016-2023") +
theme_minimal()

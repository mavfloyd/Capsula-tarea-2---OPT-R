Educacion = m01,
Sexo = m0_sexo,
Merito_Esfuerzo = c18_09,
Merito_Talento = c18_10,
Igualdad_Oport = c18_13) %>%
# Es importantisimo asegurar que los ítems de la escala sean numéricos!!!
mutate(Merito_Esfuerzo = as.numeric(Merito_Esfuerzo),
Merito_Talento = as.numeric(Merito_Talento),
Igualdad_Oport = as.numeric(Igualdad_Oport)) %>%
# Al final, limpiamos los NAs para que la escala y la correlación funcionen bien
na.omit()
#| label: cronbach-escala
# 1. Aislamos solo los ítems que formarán la escala
items_merito <- elsoc_trabajo3 %>%
select(Merito_Esfuerzo, Merito_Talento, Igualdad_Oport)
# 2. Calculamos el Alfa de Cronbach (usando el paquete psych)
alfa_resultado <- psych::alpha(items_merito)
# Mostramos el resultado en consola para analizar el raw_alpha y el alpha.drop
alfa_resultado
# 3. Si el Alfa es bueno (> 0.7), construimos la escala con el promedio

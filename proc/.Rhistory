# 1. Tabla para Educación
tabla_educ <- elsoc_proc %>%
count(Educacion) %>%
mutate(
freq_abs = n,                              # Frecuencia Absoluta
freq_acum = cumsum(n),                     # Frecuencia Acumulada
freq_rel = (n / sum(n)) * 100,             # Frecuencia Relativa (%)
freq_rel_acum = cumsum(freq_rel)           # Frecuencia Relativa Acumulada (%)
) %>%
select(-n) # Quitamos la columna 'n' original porque ya la duplicamos
# Formato Kable
tabla_educ %>%
kable(caption = "Tabla 2. Distribución de Nivel Educacional",
digits = 1,
format = "html",
col.names = c("Categoría", "Frec. Absoluta", "Frec. Acumulada", "Frec. Relativa (%)", "Frec. Rel. Acum (%)")) %>%
kable_styling(bootstrap_options = c("striped", "hover"), full_width = F)
tabla_educ_final %>%
save_kable(file = "../output/tables/tabla_2_educacion.png", zoom = 3)

grafico_sueldo <- ggplot(elsoc_proc, aes(x = Sueldo)) +
geom_histogram(fill = "#294D8F", color = "white", bins = 50) +
geom_vline(aes(xintercept = median(Sueldo)), color = "#FFAD33", linetype = "dashed", size = 1) +
# Usamos una función personalizada dentro de labels
scale_x_continuous(
breaks = seq(0, 20000000, by = 1000000), # Cortes cada 1 millón
labels = function(x) {
ifelse(x == 0, "$0", paste0("$", x/1000000, "M"))
}
) +
labs(title = "Distribución del Sueldo Líquido Mensual",
subtitle = "La línea amarilla indica la mediana. Eje X en millones de pesos (M)",
x = "Sueldo",
y = "Frecuencia",
caption = "Fuente: Elab. Propia a partir de ELSOC 2016-2023") +
theme_minimal()
ggsave(filename = "../output/graphs/grafico_sueldo.png",
plot = grafico_sueldo,
width = 10,
height = 6,
dpi = 300)
# Gráfico 2: Distribución de Nivel Educacional
grafico_educ <- ggplot(elsoc_proc, aes(x = Educacion, fill = Educacion)) +
geom_bar() +
coord_flip() + # Giramos el gráfico para leer bien las etiquetas
labs(title = "Nivel Educacional de los Encuestados",
x = "Nivel de Estudios",
y = "Cantidad de Casos",
caption = "Fuente: Elab. Propia a partir de ELSOC 2016-2023") +
scale_fill_viridis_d(option = "plasma", guide = "none") + # Colores bonitos y sin leyenda innecesaria
theme_classic()
ggsave(filename = "../output/graphs/grafico_educ.png",
plot = grafico_educ,
width = 10,
height = 6,
dpi = 300)
#| label: preparacion-escala
elsoc_trabajo3 <- elsoc %>%
select(m13, m0_edad, m01, m0_sexo, c18_09, c18_10, c18_13) %>%
set_na(na = c(-888, -999, 999999999)) %>%
rename(Sueldo = m13,
Edad = m0_edad,
Educacion = m01,
Sexo = m0_sexo,
Merito_Esfuerzo = c18_09,
Merito_Talento = c18_10,
Igualdad_Oport = c18_13) %>%
# Es importantisimo asegurar que los ítems de la escala sean numéricos!!!
mutate(Merito_Esfuerzo = as.numeric(Merito_Esfuerzo),
Merito_Talento = as.numeric(Merito_Talento),
Igualdad_Oport = as.numeric(Igualdad_Oport)) %>%
# Al final, limpiamos los NAs para que la escala y la correlación funcionen bien
na.omit()
#| label: cronbach-escala
# 1. Aislamos solo los ítems que formarán la escala
items_merito <- elsoc_trabajo3 %>%
select(Merito_Esfuerzo, Merito_Talento, Igualdad_Oport)
# 2. Calculamos el Alfa de Cronbach (usando el paquete psych)
alfa_resultado <- psych::alpha(items_merito)
# Mostramos el resultado en consola para analizar el raw_alpha y el alpha.drop
alfa_resultado
# 3. Si el Alfa es bueno (> 0.7), construimos la escala con el promedio
elsoc_trabajo3 <- elsoc_trabajo3 %>%
mutate(esc_meritocracia = rowMeans(items_merito, na.rm = TRUE))
#| label: matriz-correlacion
# 1. Seleccionamos solo las variables continuas/numéricas para correlacionar
variables_correlacion <- elsoc_trabajo3 %>%
select(Sueldo, Edad, esc_meritocracia)
# 2. Calculamos la matriz matemática (Pearson)
matriz_cor <- cor(variables_correlacion, use = "complete.obs")
# 3. Formateamos la tabla para el reporte formal (Exportada a la carpeta tables)
tabla_correlaciones <- matriz_cor %>%
kable(caption = "Tabla 4. Matriz de correlaciones de Pearson",
digits = 2,
format = "html",
col.names = c("Sueldo Líquido", "Edad", "Escala Meritocracia")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"), full_width = F)
# Mostrar en el HTML
tabla_correlaciones
# Exportar al formato IPO
tabla_correlaciones %>%
save_kable(file = "../output/tables/matriz_correlaciones.png", zoom = 3)
# 4. Gráfico de apoyo visual para las correlaciones (Exportado a graphs)
grafico_cor <- sjPlot::sjp.corr(variables_correlacion,
data = NULL,
decimals = 2,
title = "Matriz de Asociación Lineal")
#| label: matriz-correlacion
# 1. Seleccionamos solo las variables continuas/numéricas para correlacionar
variables_correlacion <- elsoc_trabajo3 %>%
select(Sueldo, Edad, esc_meritocracia)

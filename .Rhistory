# Gestión de librerías y paquetes.
if (!require("pacman")) install.packages("pacman")
pacman::p_load(
tidyverse,    # Manipulación de datos y ggplot2
haven,        # Lectura de archivos .sav (SPSS)
sjmisc,       # Análisis descriptivo y frecuencias
knitr,        # Renderizado de tablas
kableExtra,   # Formateo avanzado y exportación de tablas
sjPlot,       # Visualización de datos sociológicos
here,         # Gestión de rutas relativas
webshot2,     # Motor para guardar tablas como imagen
janitor,      # Limpieza de nombres y tablas
summarytools  # Resúmenes de datos
)
rm(list = ls()) # Limpiar entorno de trabajo
elsoc <- read_sav("../input/data/ELSOC_Long_2016_2023.sav")
elsoc_proc <- elsoc %>%
# 1. Seleccionamos las variables
select(m13, m0_edad, m01, m0_sexo) %>%
set_na(na = c(-888, -999, 999999999)) %>%
# 3. Etiquetamos las variables categoricas
mutate(m0_sexo = as_factor(m0_sexo),
m01 = as_factor(m01)) %>%
# 4. Renombramos las variables
rename(Sueldo = m13,
Edad = m0_edad,
Educacion = m01,
Sexo = m0_sexo) %>%
# 5. Quitamos las filas con datos perdidos
na.omit()
View(elsoc_proc)
# 1. Creamos la tabla
tabla_descriptivos <- elsoc_proc %>%
select(Sueldo, Edad) %>%
pivot_longer(cols = everything(), names_to = "Variable", values_to = "Valor") %>%
group_by(Variable) %>%
summarise(
Minimo = min(Valor),
Media = mean(Valor),
Mediana = median(Valor),
Maximo = max(Valor),
SD = sd(Valor),
)
# 2. Le damos formato con kable
tabla_final_descriptivos <- tabla_descriptivos %>%
mutate(Variable = case_when(Variable == "Sueldo" ~ "Sueldo Líquido",
Variable == "Edad" ~ "Edad")) %>%
kable(caption = "Tabla 1. Estadísticos descriptivos de Sueldo y Edad",
digits = 0,
format = "html",
col.names = c("Variable", "Mínimo", "Media", "Mediana", "Máximo", "D.E.")) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"),
full_width = F,
position = "center") %>%
column_spec(1, bold = T)
tabla_final_descriptivos
tabla_final_descriptivos %>%
save_kable(file = "../output/tables/tabla_descriptivos.png", zoom = 3)
# 1. Tabla para Educación
tabla_educ <- elsoc_proc %>%
count(Educacion) %>%
mutate(
freq_abs = n,                              # Frecuencia Absoluta
freq_acum = cumsum(n),                     # Frecuencia Acumulada
freq_rel = (n / sum(n)) * 100,             # Frecuencia Relativa (%)
freq_rel_acum = cumsum(freq_rel)           # Frecuencia Relativa Acumulada (%)
) %>%
select(-n) # Quitamos la columna 'n' original porque ya la duplicamos
# Formato Kable
tabla_educ_final <- tabla_educ %>%
kable(caption = "Tabla 2. Distribución de Nivel Educacional",
digits = 1,
format = "html",
col.names = c("Categoría", "Frec. Absoluta", "Frec. Acumulada", "Frec. Relativa (%)", "Frec. Rel. Acum (%)")) %>%
kable_styling(bootstrap_options = c("striped", "hover"), full_width = F)
tabla_educ_final %>%
save_kable(file = "../output/tables/tabla_educacion.png", zoom = 3)
View(tabla_educ)
# Tabla para Sexo
tabla_sexo <- elsoc_proc %>%
count(Sexo) %>%
mutate(
freq_abs = n,
freq_acum = cumsum(n),
freq_rel = (n / sum(n)) * 100,
freq_rel_acum = cumsum(freq_rel)
) %>%
select(-n)
# Formato Kable
tabla_sexo_final <- tabla_sexo  %>%
kable(caption = "Tabla 3. Distribución por Sexo",
digits = 1,
format = "html",
col.names = c("Categoría", "Frec. Absoluta", "Frec. Acumulada", "Frec. Relativa (%)", "Frec. Rel. Acum (%)")) %>%
kable_styling(bootstrap_options = c("striped", "hover"), full_width = F)
tabla_sexo_final %>%
save_kable(file = "../output/tables/tabla_sexo.png", zoom = 3)
View(tabla_sexo)
View(tabla_educ)
grafico_sueldo <- ggplot(elsoc_proc, aes(x = Sueldo)) +
geom_histogram(fill = "#6C8DE6", color = "white", bins = 50) +
geom_vline(aes(xintercept = median(Sueldo)), color = "#FFAD33", linetype = "dashed", size = 1) +
# Usamos una función personalizada dentro de labels
scale_x_continuous(
breaks = seq(0, 20000000, by = 1000000), # Cortes cada 1 millón
labels = function(x) {
ifelse(x == 0, "$0", paste0("$", x/1000000, "M"))
}
) +
labs(title = "Distribución del Sueldo Líquido Mensual",
subtitle = "La línea amarilla indica la mediana. Eje X en millones de pesos (M)",
x = "Sueldo",
y = "Frecuencia",
caption = "Fuente: Elab. Propia a partir de ELSOC 2016-2023") +
theme_minimal()
ggsave(filename = "../output/graphs/grafico_sueldo.png",
plot = grafico_sueldo,
width = 10,
height = 6,
dpi = 300)
View(elsoc_proc)
# Gráfico 2: Distribución de Nivel Educacional
grafico_educ <- ggplot(elsoc_proc, aes(x = Educacion, fill = Educacion)) +
geom_bar() +
coord_flip() + # Giramos el gráfico para leer bien las etiquetas
labs(title = "Nivel Educacional de los Encuestados",
x = "Nivel de Estudios",
y = "Cantidad de Casos",
caption = "Fuente: Elab. Propia a partir de ELSOC 2016-2023") +
scale_fill_viridis_d(option = "plasma", guide = "none") + # Colores bonitos y sin leyenda innecesaria
theme_classic()
ggsave(filename = "../output/graphs/grafico_educ.png",
plot = grafico_educ,
width = 10,
height = 6,
dpi = 300)
if (Sys.info()["user"] == "erick") {
